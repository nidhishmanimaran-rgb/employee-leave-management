@model EmployeeLeaveManagementSystem.Models.RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
}

<section class="auth-shell">
    <div class="login-panel">
        <div class="login-heading">
            <p class="eyebrow">Employee Registration</p>
            <h1>Create account</h1>
            <p>Submit your employee details. HR will review and activate the account before you can log in.</p>
        </div>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-error">@TempData["ErrorMessage"]</div>
        }

        <form asp-controller="Auth" asp-action="Register" method="post" class="leave-form">
            <div class="form-section compact-section">
                <div class="form-group">
                    <label asp-for="Name">Name</label>
                    <input asp-for="Name" class="form-control" autocomplete="name" placeholder="Employee Name" />
                    <span asp-validation-for="Name" class="validation"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Email">Company Email</label>
                    <input asp-for="Email" class="form-control" autocomplete="email" placeholder="nidhishkumaranm@gmail.com" />
                    <span asp-validation-for="Email" class="validation"></span>
                </div>

                <div class="field-grid two-columns">
                    <div class="form-group">
                        <label asp-for="Department">Department</label>
                        <input asp-for="Department" class="form-control" placeholder="IT" />
                        <span asp-validation-for="Department" class="validation"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Designation">Designation</label>
                        <input asp-for="Designation" class="form-control" placeholder="Software Engineer" />
                        <span asp-validation-for="Designation" class="validation"></span>
                    </div>
                </div>

                <div class="form-group">
                    <label asp-for="Password">Password</label>
                    <input asp-for="Password" class="form-control" autocomplete="new-password" />
                    <span asp-validation-for="Password" class="validation"></span>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn">Submit for Approval</button>
                <a class="auth-secondary-link" asp-controller="Auth" asp-action="Login">Back to Login</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
