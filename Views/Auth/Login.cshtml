@model EmployeeLeaveManagementSystem.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<section class="auth-shell">
    <div class="login-panel">
        <div class="login-heading">
            <p class="eyebrow">Company Login</p>
            <h1>Sign in</h1>
            <p>Use your company email and password. The system will open the correct dashboard for your role.</p>
        </div>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-error">@TempData["ErrorMessage"]</div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }

        <form asp-controller="Auth" asp-action="Login" method="post" class="leave-form">
            <div class="form-section compact-section">
                <div class="form-group">
                    <label asp-for="Email">Company Email</label>
                    <input asp-for="Email" class="form-control" autocomplete="username" placeholder="employee@company.com" />
                    <span asp-validation-for="Email" class="validation"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password">Password</label>
                    <input asp-for="Password" class="form-control" autocomplete="current-password" />
                    <span asp-validation-for="Password" class="validation"></span>
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn">Continue</button>
                <a class="auth-secondary-link" asp-controller="Auth" asp-action="Register">Create Account</a>
            </div>
        </form>

        <div class="demo-login-grid">
            <span>Admin: nidhishmanimaran@gmail.com</span>
            <span>Employee: nidhishkumaranm@gmail.com</span>
            <span>Manager: manager@company.com</span>
            <span>HR: hr@company.com</span>
            <strong>Password: 12345678</strong>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
