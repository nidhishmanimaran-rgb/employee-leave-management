@{
    ViewData["Title"] = "HR Login";
}

<section class="auth-shell">
    <div class="login-panel">
        <div class="login-heading">
            <p class="eyebrow">Secure HR Area</p>
            <h1>HR Dashboard Login</h1>
            <p>Review requests, decisions, and employee leave history.</p>
        </div>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-error">@TempData["ErrorMessage"]</div>
        }

        <form asp-controller="HrDashboard" asp-action="Login" method="post" class="leave-form">
            <div class="form-section compact-section">
                <div class="form-group">
                    <label for="username">Username</label>
                    <input id="username" name="username" class="form-control" autocomplete="username" />
                </div>

                <div class="form-group">
                    <label for="password">Password</label>
                    <input id="password" name="password" type="password" class="form-control" autocomplete="current-password" />
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn">Login</button>
            </div>
        </form>
    </div>
</section>
